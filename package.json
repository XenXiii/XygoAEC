{
  "name": "xygo-ai-aec-os",
  "version": "0.0.0-phase0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "node --test packages/*/test/**/*.test.js apps/*/test/**/*.test.js",
    "test:staged-mode": "node --test packages/staged-mode/test/**/*.test.js",
    "test:foundation": "node --test packages/{shared-contracts,auth,authorization,audit}/test/**/*.test.js",
    "verify:audit": "node ./packages/audit/src/verify.js",
    "test:api": "node --test apps/api/test/**/*.test.js",
    "test:web": "node --test apps/web/test/**/*.test.js"
  }
}
