          }
        }
      }
    },
    "/v1/tenants/{tenantId}/events/stream": {
      "get": {
        "summary": "Open staged tenant event stream",
        "security": [
          { "stagedTenantQuery": [] }
        ],
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "stagedTenantId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SSE stream"
          },
          "403": {
            "description": "tenant mismatch"
          }
        }
      }
    },
    "/v1/tenants/{tenantId}/audit-events": {
      "get": {
        "summary": "List staged tenant audit events",
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
