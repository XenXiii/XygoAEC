          }
        }
      }
    },
    "/v1/tenants/{tenantId}/audit-events/verify": {
      "get": {
        "summary": "Verify staged tenant audit chain",
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "audit verification report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditVerificationReport"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tenants/{tenantId}/transfers": {
      "get": {
        "summary": "Return staged transfer queue summary",
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "transfer queue"
          }
        }
      }
    }
  }
}
